# Google Drive 루트 폴더 ID
# Drive URL에서 확인: https://drive.google.com/drive/folders/<FOLDER_ID>
FOLDER_ID=your_root_folder_id

# 관리자 비밀번호 (평문)
# 클라이언트는 SHA-256 해싱 후 POST /api/rebuild 로 전송
ADMIN_PASSWORD=admin1234

# OAuth 콜백 URI (Google Cloud Console의 승인된 리디렉션 URI와 일치해야 함)
# 로컬 테스트: http://localhost/oauth/callback
# 실제 도메인: https://your-domain.com/oauth/callback
OAUTH_REDIRECT_URI=http://localhost/oauth/callback
